  "description": "",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev:entry": "tsx watch --ignore ./src/scripts --clear-screen=false src/main.ts",
    "prettier": "prettier --write .",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "jest --roots src --coverage",
    "generate:openapi": "tsx ./src/scripts/generate-openapi.ts",
    "generate:openapi:watch": "tsx watch ./src/scripts/generate-openapi.ts",
    "dev": "concurrently \"pnpm run dev:entry\" \"pnpm run generate:openapi:watch\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "exports": {
    "import": "./dist/index.js",
    "require": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "dependencies": {
