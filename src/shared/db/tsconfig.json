{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "..",
    "isolatedModules": true,
    "paths": {
      "@types": ["../types/src/index"],
      "@types/*": ["../types/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "build"],
  "include": ["src/**/*.ts", "../types/src/**/*.ts"]
}
